{
  "name": "qs-to-filter",
  "version": "0.1.7",
  "description": "Type-safe query string to database filter conversion with security built-in",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mongo": {
      "types": "./dist/mongo.d.ts",
      "default": "./dist/mongo.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "default": "./dist/postgres.js"
    },
    "./adapters/zod": {
      "types": "./dist/adapters/zod.d.ts",
      "default": "./dist/adapters/zod.js"
    },
    "./adapters/valibot": {
      "types": "./dist/adapters/valibot.d.ts",
      "default": "./dist/adapters/valibot.js"
    },
    "./adapters/typebox": {
      "types": "./dist/adapters/typebox.d.ts",
      "default": "./dist/adapters/typebox.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm build",
    "build": "pkgroll --target=node18",
    "dev": "pkgroll --watch",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "format": "biome format src",
    "format:fix": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test:run"
  },
  "keywords": [
    "query-string",
    "filter",
    "mongodb",
    "postgres",
    "postgresql",
    "api",
    "rest",
    "typescript",
    "query-params",
    "database",
    "zod",
    "valibot",
    "typebox"
  ],
  "author": "mikipavlov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikipavlov/qs-to-filter.git"
  },
  "bugs": {
    "url": "https://github.com/mikipavlov/qs-to-filter/issues"
  },
  "homepage": "https://github.com/mikipavlov/qs-to-filter#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "qs": "^6.14.0"
  },
  "peerDependencies": {
    "@sinclair/typebox": ">=0.32.0",
    "mongodb": ">=5.0.0",
    "valibot": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^22.0.0",
    "@types/qs": "^6.9.18",
    "@vitest/coverage-v8": "^3.0.0",
    "mongodb": "^6.19.0",
    "pkgroll": "^2.11.2",
    "release-it": "^19.2.4",
    "typescript": "^5.8.0",
    "valibot": "^1.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.28"
  }
}
